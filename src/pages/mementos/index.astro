---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const mementos = (await getCollection("mementos")).sort(
  (a, b) => a.data.number - b.data.number
);
---

<Layout title="Mementos · InterStellar AI">
  <section class="pf-hero">
    <div class="wrap-prose">
      <h1>Decision log</h1>
      <p class="lede">Architecture Decision Records for the InterStellar AI portfolio. Each entry captures what was decided, why, and the alternatives we rejected.</p>
    </div>
  </section>
  <section class="adr-body">
    <div class="wrap-prose">
      <div class="mementos">
        {mementos.map((m) => (
          <a class="dec" href={`/mementos/${m.slug}`}>
            <span class="num">{String(m.data.number).padStart(3, "0")}</span>
            <span class="title">{m.data.title}</span>
            <span class="meta-date">{m.data.date.toISOString().slice(0, 10)}</span>
            <span class="meta-status">
              <span class={`badge badge-${m.data.status}`}>{m.data.status}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
