---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const mementos = await getCollection("mementos");
  return mementos.map((m) => ({ params: { slug: m.slug }, props: { memento: m } }));
}

const { memento } = Astro.props;
const { Content } = await memento.render();
const adrNum = String(memento.data.number).padStart(3, "0");
---

<Layout title={`ADR-${adrNum}: ${memento.data.title}`}>
  <section class="adr-head">
    <div class="wrap-prose">
      <div class="crumbs"><a href="/mementos">← all mementos</a></div>
      <h1>ADR-{adrNum}: {memento.data.title}</h1>
      <div class="adr-meta">
        <span><strong>Status</strong>: {memento.data.status}</span>
        <span><strong>Date</strong>: {memento.data.date.toISOString().slice(0, 10)}</span>
        {memento.data.projects && (
          <span><strong>Applies to</strong>: {memento.data.projects.join(", ")}</span>
        )}
      </div>
    </div>
  </section>
  <section class="adr-body">
    <div class="wrap-prose">
      <Content />
    </div>
  </section>
</Layout>
