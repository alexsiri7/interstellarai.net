---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const decisions = (await getCollection("decisions")).sort(
  (a, b) => a.data.number - b.data.number
);
---

<Layout title="Decisions · InterStellar AI">
  <section class="pf-hero">
    <div class="wrap-prose">
      <h1>Decision log</h1>
      <p class="lede">Architecture Decision Records for the InterStellar AI portfolio. Each entry captures what was decided, why, and the alternatives we rejected.</p>
    </div>
  </section>
  <section class="adr-body">
    <div class="wrap-prose">
      <ol class="decisions">
        {decisions.map((d) => (
          <a class="dec" href={`/decisions/${d.slug}`}>
            <span class="num">{String(d.data.number).padStart(3, "0")}</span>
            <span class="title">{d.data.title}</span>
            <span class="meta-date">{d.data.date.toISOString().slice(0, 10)}</span>
            <span class="meta-status">
              <span class={`badge badge-${d.data.status}`}>{d.data.status}</span>
            </span>
          </a>
        ))}
      </ol>
    </div>
  </section>
</Layout>
