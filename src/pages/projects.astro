---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Projects · InterStellar AI">
  <section class="pf-hero">
    <div class="wrap">
      <h1>The <em>portfolio</em></h1>
      <p class="lede">The portfolio at a glance. For deploy and hosting defaults, see <a href="/mementos/003-per-project-deploy-targets">ADR-003</a>. Each project's own repo documents its specifics.</p>
    </div>
  </section>
  <section class="pf-body">
    <div class="wrap">
      <div class="pf-shape-group">
        <div class="pf-shape-head">
          <h2>Web backends</h2>
          <span class="pf-shape-meta eyebrow">Railway · managed Postgres</span>
        </div>
        <div class="pf-list-row">
          <a class="pf-row" href="https://filmduel.interstellarai.net">
            <span class="name"><em>Film</em>Duel</span>
            <span class="desc">Movie and TV ranking via ELO duels. FastAPI + React, PostgreSQL/Supabase.</span>
            <span class="stack">FastAPI · React · Postgres</span>
            <span class="status"><span class="badge badge-live">live</span></span>
          </a>
          <a class="pf-row" href="https://reli.interstellarai.net">
            <span class="name">Reli</span>
            <span class="desc">Personal AI assistant with a knowledge graph. Python/FastAPI + React, Postgres with pgvector.</span>
            <span class="stack">FastAPI · React · pgvector</span>
            <span class="status"><span class="badge badge-wip">wip</span></span>
          </a>
          <a class="pf-row" href="https://annie.interstellarai.net">
            <span class="name"><em>Word Coach</em> Annie</span>
            <span class="desc">AI writing assistant for novelists. Next.js 15, PostgreSQL/Supabase, Prisma, with an MCP server exposing 48 tools.</span>
            <span class="stack">Next.js · Supabase · Prisma</span>
            <span class="status"><span class="badge badge-wip">wip</span></span>
          </a>
        </div>
      </div>

      <div class="pf-shape-group">
        <div class="pf-shape-head">
          <h2>Mobile</h2>
          <span class="pf-shape-meta eyebrow">Android · on-device</span>
        </div>
        <div class="pf-list-row">
          <div class="pf-row">
            <span class="name"><em>Cosmic</em> Match</span>
            <span class="desc">Space-themed match-3 mobile game. Flutter + Flame, Android.</span>
            <span class="stack">Flutter · Flame</span>
            <span class="status"><span class="badge badge-wip">wip</span></span>
          </div>
          <div class="pf-row">
            <span class="name">The <em>Un-Reminder</em></span>
            <span class="desc">Stochastic, context-aware habit prompts designed to defeat notification blindness. Native Android, on-device AI, no backend.</span>
            <span class="stack">Android · on-device AI</span>
            <span class="status"><span class="badge badge-wip">wip</span></span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
