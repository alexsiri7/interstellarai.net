---
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "InterStellar AI — building AI-native software, in public." } = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en" data-dir="b">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-brand" href="/">
          <svg width="28" height="28" viewBox="0 0 64 64" fill="none" aria-hidden="true" style="flex-shrink:0">
            <ellipse cx="32" cy="32" rx="26" ry="10" transform="rotate(-24 32 32)"
              stroke="currentColor" stroke-width="2.5" fill="none"/>
            <ellipse cx="32" cy="32" rx="20" ry="8" transform="rotate(24 32 32)"
              stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.6" stroke-dasharray="2 3"/>
            <circle cx="32" cy="32" r="6" fill="#D97757"/>
            <circle cx="52" cy="22" r="2.2" fill="currentColor"/>
          </svg>
          <span><em>Interstellar</em><span class="ai">AI</span></span>
        </a>
        <div class="nav-links">
          <a class={`nav-link ${path === '/' ? 'is-active' : ''}`} href="/">Home</a>
          <a class={`nav-link ${path.startsWith('/tenets') ? 'is-active' : ''}`} href="/tenets">Tenets</a>
          <a class={`nav-link ${path.startsWith('/decisions') ? 'is-active' : ''}`} href="/decisions">Decisions</a>
          <a class={`nav-link ${path.startsWith('/projects') ? 'is-active' : ''}`} href="/projects">Projects</a>
        </div>
        <div class="nav-right">
          <a class="nav-ghost-link" href="https://github.com/alexsiri7/interstellarai.net" target="_blank" rel="noreferrer">github ↗</a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="footer-inner">
        <div>
          <div class="brand">
            <svg width="30" height="30" viewBox="0 0 64 64" fill="none" aria-hidden="true">
              <ellipse cx="32" cy="32" rx="26" ry="10" transform="rotate(-24 32 32)" stroke="#FAF7F2" stroke-width="2.5" fill="none"/>
              <circle cx="32" cy="32" r="6" fill="#D97757"/>
              <circle cx="52" cy="22" r="2.5" fill="#FAF7F2"/>
            </svg>
            <span><em>Interstellar</em><span class="ai">AI</span></span>
          </div>
          <p class="tagline">Small, AI-driven software projects and the engineering handbook that keeps them shipping.</p>
        </div>
        <div class="footer-cols">
          <div>
            <div class="footer-h">Handbook</div>
            <a href="/tenets">Tenets</a>
            <a href="/decisions">Decision log</a>
            <a href="/projects">Projects</a>
          </div>
          <div>
            <div class="footer-h">Projects</div>
            <a href="https://filmduel.interstellarai.net" target="_blank" rel="noreferrer">FilmDuel</a>
            <a href="https://github.com/alexsiri7/Archon" target="_blank" rel="noreferrer">Archon</a>
            <a href="https://github.com/alexsiri7/un-reminder" target="_blank" rel="noreferrer">un-reminder</a>
            <a href="https://github.com/alexsiri7/cosmic-match" target="_blank" rel="noreferrer">Cosmic Match</a>
          </div>
          <div>
            <div class="footer-h">Elsewhere</div>
            <a href="https://github.com/alexsiri7" target="_blank" rel="noreferrer">GitHub</a>
          </div>
        </div>
      </div>
      <div class="footer-foot">
        <span>&copy; 2026 InterstellarAI &middot; Made in orbit</span>
        <span>&#10038; Deployed via the pipeline &middot; Cloudflare Pages</span>
      </div>
    </footer>
  </body>
</html>
